# ============================================================
# VaultOne Bulk Resource Manager - configuration
# Copy this file to ".env" and fill in your own values.
# The .env file is git-ignored and must NEVER be committed.
# ============================================================

# Authentication endpoint (token issuance)
VAULTONE_AUTH_URL=https://<your-tenant>.api.vault.jumpcloud.com

# API endpoint (all resource calls)
VAULTONE_API_URL=https://<your-tenant>.app.vault.jumpcloud.com

# API user credentials
VAULTONE_USERNAME=your-api-user
VAULTONE_PASSWORD=your-api-password

# Tenant ID (abp-tenantid header). Default is 101.
VAULTONE_TENANT_ID=101

# Optional: set to "true" to print full API responses for debugging.
VAULTONE_VERBOSE=false

# Optional: override the folder the sample/input CSVs are read from.
# VAULTONE_CSV_DIR=/path/to/your/csvs
